#!/usr/bin/env bash

set -euo pipefail

export PYTHONPATH="/home/clar/Scripts/omarchy-focus/src${PYTHONPATH:+:$PYTHONPATH}"
PYTHON_BIN="/home/clar/.local/share/clar-focus/venv/bin/python"
if [[ ! -x "$PYTHON_BIN" ]]; then
  PYTHON_BIN="/home/clar/.local/share/omarchy-focus/venv/bin/python"
fi
exec "$PYTHON_BIN" -m omarchy_focus.legacy "$@"
